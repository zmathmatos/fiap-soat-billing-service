# App
BUILD_TARGET=development
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://mongo:27017/billing

# Mercado Pago
MP_ACCESS_TOKEN=your_mercado_pago_access_token
MP_WEBHOOK_SECRET=your_webhook_secret

# SMTP (Mailhog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=billing@fiap-soat.com

# OS Service
OS_SERVICE_URL=http://fiap-web-dev:3000

# RabbitMQ (broker runs in the fiap-soat-os-service dev stack, shared via the fiap-net network)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=payment-events
RABBITMQ_QUEUE=billing-queue
